{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "project": ["*.js"]
    },
    "packages/build": {
      "project": ["src/**/*.js", "src/**/*.ts"],
      "ignoreDependencies": ["@lvce-editor/verror", "esbuild"]
    },
    "packages/running-extensions-view": {
      "entry": ["test/**/*.test.ts"],
      "project": ["src/**/*.ts", "test/**/*.ts"]
    }
  }
}
