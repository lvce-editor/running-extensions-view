{
  "name": "@lvce-editor/running-extensions-view-monorepo",
  "version": "0.0.0-dev",
  "keywords": [
    "running-extensions"
  ],
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "npm exec --workspace=packages/build -- esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads --bundle --watch ../running-extensions-view/src/runningExtensionsViewMain.ts --outfile=../../.tmp/dist/dist/runningExtensionsViewMain.js",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "npm run e2e --workspace=packages/e2e",
    "e2e:firefox": "npm run e2e:firefox --workspace=packages/e2e",
    "e2e:firefox:headless": "npm run e2e:firefox:headless --workspace=packages/e2e",
    "e2e:headless": "npm run e2e:headless --workspace=packages/e2e",
    "e2e:webkit": "npm run e2e:webkit --workspace=packages/e2e",
    "e2e:webkit:headless": "npm run e2e:webkit:headless --workspace=packages/e2e",
    "format": "prettier --write .",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "test": "npm test --workspaces --if-present",
    "type-check": "tsc -b"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,js",
    "exec": "node scripts/build.js"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lvce-editor/eslint-config": "^16.4.0",
    "eslint": "^10.7.0",
    "knip": "^6.26.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  }
}
