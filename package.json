{
  "name": "@lvce-editor/running-extensions-view-monorepo",
  "version": "0.0.0-dev",
  "keywords": [
    "running-extensions"
  ],
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "scripts": {
    "build": "node packages/build/src/build.ts",
    "build:static": "node packages/build/src/build-static.ts",
    "build:watch": "./packages/build/node_modules/.bin/esbuild --format=esm --bundle --external:node:buffer --external:electron --external:ws --external:node:worker_threads --bundle --watch packages/running-extensions-view/src/runningExtensionsViewMain.ts --outfile=.tmp/dist/dist/runningExtensionsViewMain.js",
    "dev": "node packages/build/src/dev.ts",
    "e2e": "cd packages/e2e && npm run e2e",
    "e2e:firefox": "cd packages/e2e && npm run e2e:firefox",
    "e2e:firefox:headless": "cd packages/e2e && npm run e2e:firefox:headless",
    "e2e:headless": "cd packages/e2e && npm run e2e:headless",
    "e2e:webkit": "cd packages/e2e && npm run e2e:webkit",
    "e2e:webkit:headless": "cd packages/e2e && npm run e2e:webkit:headless",
    "format": "prettier --write .",
    "postinstall": "lerna bootstrap --ci",
    "lint": "eslint . && prettier --check . && knip --no-config-hints",
    "test": "lerna run test",
    "type-check": "tsc -b"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "ts,js",
    "exec": "node scripts/build.js"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 150
  },
  "devDependencies": {
    "@lerna/legacy-package-management": "^8.2.4",
    "@lvce-editor/eslint-config": "^16.3.0",
    "eslint": "^10.7.0",
    "knip": "^6.26.0",
    "lerna": "^8.2.4",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3"
  }
}
